{
  "name": "four_state_z2x_z2_v0_1",
  "version": "0.1",
  "status": "draft",
  "purpose": "Refined four-state model using two binary generators.",
  "generators": {
    "m": {
      "name": "mirror_rotation",
      "action": "toggle across row relation"
    },
    "d": {
      "name": "diameter_flip",
      "action": "toggle across column relation"
    }
  },
  "states": [
    { "state_id": "s00", "bits": [0, 0] },
    { "state_id": "s10", "bits": [1, 0] },
    { "state_id": "s01", "bits": [0, 1] },
    { "state_id": "s11", "bits": [1, 1] }
  ],
  "transition_rules": {
    "row_move": "toggle m",
    "column_move": "toggle d",
    "diagonal_move": "toggle m and d"
  },
  "canonical_sentence": "The four-state family is a Z2 x Z2 state space generated by mirror-rotation and diameter-flip."
}
